{
	"version": 1,
	"base_image": "codeocean/mambaforge3:23.1.0-4-python3.10.12-ubuntu22.04",
	"args": [
		"CUSTOM_KEY",
		"CUSTOM_KEY_2",
		"CUSTOM_KEY_3"
	],
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true
	},
	"installers": {
		"pip3": {
			"packages": [
				{
					"name": "anthropic"
				},
				{
					"name": "dotenv"
				},
